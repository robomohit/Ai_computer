# Copy to ".env" in this folder and fill in values. Never commit ".env" (it is gitignored).

# ── LLM keys (at least one required) ───────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── API / session ───────────────────────────────────────────────────────────
AGENT_API_KEY=
SESSION_TTL_SECONDS=
SESSION_COOKIE_SECURE=

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── Agent tuning (optional) ────────────────────────────────────────────────
APPROVAL_WAIT_TIMEOUT_SECONDS=
PERMISSION_WAIT_TIMEOUT_SECONDS=
AGENT_MAX_STEPS=
BROWSER_MAX_STEPS=

# ── Browser / memory ────────────────────────────────────────────────────────
# BROWSER_HEADED=1
# USE_CHROMA=1

# ── Discord (pip install discord.py; Message Content Intent in portal) ─────
DISCORD_BOT_TOKEN=

# ── Telegram (pip install python-telegram-bot) ──────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Optional MCP-related keys ───────────────────────────────────────────────
EXA_API_KEY=
FIGMA_ACCESS_TOKEN=
TAVILY_API_KEY=
SLACK_BOT_TOKEN=
AI_COMPUTER_MCP_CONFIG=
