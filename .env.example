# ── Required: at least one LLM key ─────────────────────────────────────────
# Free option — get a key at https://openrouter.ai (no credit card needed)
OPENROUTER_API_KEY=

# Paid options (optional — leave blank if you don't have them)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── Optional settings ───────────────────────────────────────────────────────
# Secures the REST API. Auto-generated on startup if left blank.
AGENT_API_KEY=

# Show the Playwright browser window while it works (default: headless)
# BROWSER_HEADED=1

# Enable ChromaDB vector memory (requires: pip install -r requirements-memory.txt)
# USE_CHROMA=1

# CORS origins
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── Optional messaging integrations ─────────────────────────────────────────
# Telegram bot — get a token from @BotFather on Telegram (/newbot command)
# Also run: pip install python-telegram-bot
# TELEGRAM_BOT_TOKEN=

# Discord bot — create an app at https://discord.com/developers/applications
# → New Application → Bot → Reset Token
# Enable "Message Content Intent" in the Bot settings panel.
# Also run: pip install discord.py
# DISCORD_BOT_TOKEN=
